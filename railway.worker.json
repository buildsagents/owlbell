{
  "build": {
    "dockerfilePath": "backend/Dockerfile",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "restartPolicyType": "ALWAYS",
    "startCommand": "celery -A workers.celery_app:celery_app worker --loglevel=info --concurrency ${CELERY_WORKER_CONCURRENCY:-4} -Q default,onboarding,analytics"
  }
}