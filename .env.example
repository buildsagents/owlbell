# ============================================================
# Owlbell — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Security: The .env file should NEVER be committed to git.
# It contains secrets and is listed in .gitignore.
#
# Variable Categories:
#   1. Domain & SSL
#   2. Database (PostgreSQL)
#   3. Cache (Redis)
#   4. Object Storage (MinIO)
#   5. Application Security
#   6. JWT Authentication
#   7. FreeSWITCH
#   8. AI Services
#   9. Celery / Background Tasks
#   10. Monitoring & Alerting
#   11. Backup
#   12. Third-Party APIs
# ============================================================

# -----------------------------------------------------------
# 1. Domain & SSL Configuration
# -----------------------------------------------------------
# Your primary domain name
DOMAIN=owlbell.xyz

# Admin email (for SSL certificates via Let's Encrypt)
ADMIN_EMAIL=hello@owlbell.xyz

# Git SHA (set during deployment, used for image tags)
GIT_SHA=latest

# -----------------------------------------------------------
# 2. PostgreSQL Database
# -----------------------------------------------------------
POSTGRES_USER=answerflow
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=answerflow

# -----------------------------------------------------------
# 3. Redis Cache & Queue
# -----------------------------------------------------------
# No additional env vars needed — uses defaults
# Internal URLs are constructed from Docker network

# -----------------------------------------------------------
# 4. MinIO Object Storage (S3-compatible)
# -----------------------------------------------------------
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-secret-key-min-32-chars
MINIO_BUCKET_NAME=answerflow
MINIO_USE_SSL=false

# -----------------------------------------------------------
# 5. Application Security
# -----------------------------------------------------------
# Secret key for session encryption, CSRF protection, etc.
# Generate: openssl rand -base64 48
APP_SECRET_KEY=change-me-to-a-64-char-secret

# Application environment: development, staging, production
APP_ENV=production

# Debug mode (NEVER true in production)
APP_DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://owlbell.xyz,https://app.owlbell.xyz

# -----------------------------------------------------------
# 6. JWT Authentication
# -----------------------------------------------------------
# Secret key for JWT token signing
# Generate: openssl rand -base64 48
JWT_SECRET_KEY=change-me-to-a-different-jwt-secret

JWT_ALGORITHM=HS256

# Token expiration times
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------
# 7. FreeSWITCH Telephony
# -----------------------------------------------------------
# ESL (Event Socket Library) password
# Generate: openssl rand -hex 16
FREESWITCH_ESL_PASSWORD=change-me-esl-password

# -----------------------------------------------------------
# 8. AI Services Configuration
# -----------------------------------------------------------
# Ollama model to use (see: ollama.com/library)
# Recommended: phi3:mini (fast), llama3.1:8b (balanced)
OLLAMA_MODEL=phi3:mini

# Whisper model for STT
# Options: tiny, base, small, medium, large
WHISPER_MODEL=ggml-base.en.bin

# Piper voice for TTS
PIPER_VOICE=en_US-lessac-medium

# -----------------------------------------------------------
# 9. Celery / Background Tasks
# -----------------------------------------------------------
# Broker and result backend URLs (Redis)
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# Worker concurrency (number of parallel workers)
CELERY_WORKERS=4

# -----------------------------------------------------------
# 10. Monitoring & Alerting
# -----------------------------------------------------------
# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Slack webhook URL for alerts (optional)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# SMTP settings for email alerts (optional)
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@owlbell.xyz
ALERT_EMAIL_TO=oncall@owlbell.xyz

# -----------------------------------------------------------
# 11. Backup Configuration (optional)
# -----------------------------------------------------------
# Remote backup storage (rclone remote name)
# Set up with: rclone config
# Examples: mega:, pcloud:, s3:
RCLONE_REMOTE=

# Backup retention in days
BACKUP_RETENTION_DAYS=30

# Alternative: direct S3-compatible backup target
BACKUP_S3_BUCKET=
BACKUP_ACCESS_KEY=
BACKUP_SECRET_KEY=
BACKUP_S3_ENDPOINT=
BACKUP_NOTIFICATION_URL=

# -----------------------------------------------------------
# 12. Third-Party API Keys
# -----------------------------------------------------------
# Twilio (for PSTN/SMS integration — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe (for payments). NOTE: the backend reads these with the INTEGRATION_ prefix
# (IntegrationSettings in config.py). Use a sk_test_... key first.
INTEGRATION_STRIPE_SECRET_KEY=
INTEGRATION_STRIPE_PUBLISHABLE_KEY=
INTEGRATION_STRIPE_WEBHOOK_SECRET=
# Redirect URLs for Checkout + Customer Portal
INTEGRATION_STRIPE_CHECKOUT_SUCCESS_URL=https://app.owlbell.xyz/billing?status=success
INTEGRATION_STRIPE_CHECKOUT_CANCEL_URL=https://app.owlbell.xyz/billing?status=cancelled
INTEGRATION_STRIPE_BILLING_PORTAL_RETURN_URL=https://app.owlbell.xyz/billing
# Price IDs — fill these from the output of: python scripts/stripe_setup.py
INTEGRATION_STRIPE_PRICE_BASIC_MONTHLY=
INTEGRATION_STRIPE_PRICE_BASIC_ANNUAL=
INTEGRATION_STRIPE_PRICE_PRO_MONTHLY=
INTEGRATION_STRIPE_PRICE_PRO_ANNUAL=
INTEGRATION_STRIPE_PRICE_PRO_PLUS_MONTHLY=
INTEGRATION_STRIPE_PRICE_PRO_PLUS_ANNUAL=
INTEGRATION_STRIPE_PRICE_SETUP_BASIC=
INTEGRATION_STRIPE_PRICE_SETUP_PRO=

# Retell AI (for phone number provisioning and AI agents)
INTEGRATION_RETELL_API_KEY=
INTEGRATION_RETELL_WEBHOOK_SECRET=

# OpenAI (fallback AI provider — optional)
OPENAI_API_KEY=

# SendGrid (for transactional email — optional)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@owlbell.xyz

# -----------------------------------------------------------
# 13. Telephony Provider Configuration
# -----------------------------------------------------------
# SIP trunk provider credentials
# Telnyx (recommended): https://portal.telnyx.com/#/app/sip-trunks
TELNYX_SIP_USERNAME=change-me
TELNYX_SIP_PASSWORD=change-me
TELNYX_SIP_PROXY=sip.telnyx.com:5060

# Twilio (alternative): https://www.twilio.com/console/voice/sip/trunks
TWILIO_SIP_USERNAME=
TWILIO_SIP_PASSWORD=
TWILIO_SIP_PROXY=

# Operator transfer number (calls press 0 to reach this)
OPERATOR_TRANSFER_NUMBER=

# Generic SIP provider (legacy)
SIP_PROVIDER_HOST=
SIP_PROVIDER_USERNAME=
SIP_PROVIDER_PASSWORD=
SIP_PROVIDER_PORT=5060

# -----------------------------------------------------------
# 14. Feature Flags
# -----------------------------------------------------------
# Enable/disable features
ENABLE_WEBSOCKET=true
ENABLE_CALL_RECORDING=true
ENABLE_TRANSCRIPTION=true
ENABLE_AI_RESPONSES=true
ENABLE_ANALYTICS=true

# -----------------------------------------------------------
# 15. Rate Limiting
# -----------------------------------------------------------
# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------
# 16. Prometheus / Metrics
# -----------------------------------------------------------
# Multi-process metrics directory
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
METRICS_PORT=9000

# ============================================================
# Quick Reference: Secret Generation Commands
# ============================================================
# POSTGRES_PASSWORD:  openssl rand -base64 24
# APP_SECRET_KEY:     openssl rand -base64 48
# JWT_SECRET_KEY:     openssl rand -base64 48
# MINIO_SECRET_KEY:   openssl rand -hex 32
# FREESWITCH_ESL:     openssl rand -hex 16
# GRAFANA_PASSWORD:   openssl rand -base64 24
#
# ============================================================
