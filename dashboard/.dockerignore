# =============================================================================
# Owlbell — Dashboard .dockerignore
# =============================================================================
# Files excluded from Docker build context for the dashboard frontend image.
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
dist-ssr/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/
*.local

# ---------------------------------------------------------------------------
# Development tools
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.eslintcache
.stylelintcache

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
*.lcov
.playwright-report/
test-results/
__tests__/__snapshots__/

# ---------------------------------------------------------------------------
# Git & CI
# ---------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.github/
.pre-commit-config.yaml
Makefile
*.md
!README.md

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# ---------------------------------------------------------------------------
# Storybook & docs
# ---------------------------------------------------------------------------
storybook-static/
*.stories.tsx
*.stories.ts
.storybook/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
*.bak
*.backup
.terraform/
*.tfstate
