# =============================================================================
# Owlbell — Backend .dockerignore
# =============================================================================
# Files excluded from Docker build context for the backend API image.
# This keeps images small and avoids leaking secrets into layers.
# =============================================================================

# ---------------------------------------------------------------------------
# Python cache & virtual environments
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
tests/
test_data/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
nosetests.xml
tox.ini

# ---------------------------------------------------------------------------
# Development tools
# ---------------------------------------------------------------------------
*.log
logs/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# Git & CI
# ---------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.github/
.pre-commit-config.yaml
Makefile
*.md
!README.md

# ---------------------------------------------------------------------------
# Secrets (never in image)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.yaml
secrets.json

# ---------------------------------------------------------------------------
# Local data & uploads
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
uploads/
media/
local_data/

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
build/
dist/
docker/

# ---------------------------------------------------------------------------
# Documentation
# ---------------------------------------------------------------------------
docs/
*.md

# ---------------------------------------------------------------------------
# Alembic (run migrations at deploy, not build)
# ---------------------------------------------------------------------------
alembic.ini
migrations/versions/*.py
!migrations/versions/__init__.py

# ---------------------------------------------------------------------------
# Model caches (mounted at runtime)
# ---------------------------------------------------------------------------
model_cache/
whisper_cache/
piper_cache/
models/

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
