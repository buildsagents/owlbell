# ============================================================
# Owlbell — Piper TTS Server Dockerfile
# ============================================================
# Architecture: ARM64, Python HTTP wrapper
# Stages: builder (download models) → runtime (serve)
# Features: piper-tts, FastAPI wrapper, voice pre-download
# ============================================================

# ------------------------------
# Stage 1: Builder
# ------------------------------
FROM python:3.11-slim AS builder

WORKDIR /piper

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libespeak-ng1 \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install piper-tts Python package
RUN pip install --no-cache-dir piper-tts

# Download default voice model (US English, medium quality)
RUN mkdir -p /models \
    && pip install --no-cache-dir requests \
    && python3 -c "
import urllib.request
import os
base = 'https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/lessac/medium'
models = [
    ('en_US-lessac-medium.onnx', 'medium'),
    ('en_US-lessac-medium.onnx.json', 'medium'),
]
for filename, quality in models:
    url = f'{base}/{filename}'
    path = f'/models/{filename}'
    if not os.path.exists(path):
        print(f'Downloading {filename}...')
        urllib.request.urlretrieve(url, path)
        print(f'Saved to {path}')
"

# Copy server script for validation
COPY server.py /piper/server.py
RUN python3 -m py_compile /piper/server.py

# ------------------------------
# Stage 2: Runtime
# ------------------------------
FROM python:3.11-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libespeak-ng1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy Python packages from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin/piper /usr/local/bin/piper

# Copy voice models
COPY --from=builder /models /models

# Copy server script
COPY --from=builder /piper/server.py /app/server.py

# Default environment
ENV PIPER_MODEL=/models/en_US-lessac-medium.onnx
ENV PIPER_CONFIG=/models/en_US-lessac-medium.onnx.json
ENV PIPER_PORT=5000
ENV PIPER_THREADS=4
ENV PIPER_LENGTH_SCALE=1.0

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

EXPOSE 5000

CMD ["python3", "server.py"]

LABEL org.opencontainers.image.title="Owlbell - Piper TTS"
LABEL org.opencontainers.image.description="Piper text-to-speech HTTP server"
LABEL org.opencontainers.image.vendor="Owlbell"
LABEL org.opencontainers.image.source="https://github.com/answerflowai/answerflow"
