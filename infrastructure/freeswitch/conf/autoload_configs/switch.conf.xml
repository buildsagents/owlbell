; ============================================================
; Owlbell — FreeSWITCH switch.xml (minimal)
; ============================================================
; Loads only the modules Owlbell needs.
; ============================================================

<configuration name="switch.conf" description="Core Configuration">
  <settings>
    <!-- Core settings -->
    <param name="coloring-debug" value="false"/>
    <param name="max-sessions" value="1000"/>
    <param name="sessions-per-second" value="30"/>
    <param name="loglevel" value="info"/>
    <param name="dump-cores" value="yes"/>
    <param name="rtp-start-port" value="16384"/>
    <param name="rtp-end-port" value="16484"/>
  </settings>

  <!-- Modules loaded at startup -->
  <modules>
    <!-- Core -->
    <load module="mod_console"/>
    <load module="mod_logfile"/>
    <load module="mod_event_socket"/>
    <load module="mod_xml_curl"/>

    <!-- Codecs -->
    <load module="mod_pcm"/>
    <load module="mod_g722"/>
    <load module="mod_opus"/>

    <!-- SIP -->
    <load module="mod_sofia"/>

    <!-- Audio -->
    <load module="mod_audio_stream"/>
    <load module="mod_local_stream"/>
    <load module="mod_tone_stream"/>
    <load module="mod_playback"/>
    <load module="mod_record"/>

    <!-- Applications -->
    <load module="mod_dptools"/>
    <load module="mod_commands"/>
    <load module="mod_dialplan_xml"/>

    <!-- DTMF -->
    <load module="mod_dtmf"/>

    <!-- Voicemail (fallback) -->
    <load module="mod_voicemail"/>
  </modules>
</configuration>
