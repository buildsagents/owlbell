        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {"expr": "sum(rate(calls_ended_total{reason=~\"error|timeout|dropped\"}[5m])) / sum(rate(calls_ended_total[5m])) * 100", "refId": "A"}
      ],
      "title": "Call Drop Rate %",
      "type": "stat"
    },
